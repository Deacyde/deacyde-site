# GA4 & GSC Custom MCP — Environment Variables
# Copy to .env and fill in values

# Required: encryption key for stored API keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MCP_ENCRYPTION_SECRET=

# Optional: session secret (auto-generated if not set)
SESSION_SECRET=

# Optional: port (default 3100)
PORT=3100
